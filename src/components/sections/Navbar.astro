---
import MobileMenu from '../ui/MobileMenu.vue';

const navLinks = [
  { label: 'Accueil', href: '#accueil' },
  { label: 'Services', href: '#services' },
  { label: 'Tarifs', href: '#tarifs' },
  { label: 'Avis', href: '#avis' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="sticky top-0 z-40 border-b border-neutral-800 bg-neutral-950/90 backdrop-blur transition-colors supports-backdrop-filter:bg-neutral-950/75 has-[.mobile-menu-open]:bg-neutral-950 has-[.mobile-menu-open]:backdrop-blur-none">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-2">
    <!-- Logo -->
<a href="/" class="flex items-center" aria-label="Jane Doe — Accueil">
  <img
    src="/logo.svg"
    alt="Jane Doe Coaching"
    class="h-24 w-auto"
    width="96"
    height="96"
  />
</a>

    <!-- Liens desktop (cachés sur mobile) -->
    <ul class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm text-neutral-300 transition-colors hover:text-white"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Bouton Réserver (desktop uniquement) -->
    <a
      href="#contact"
      class="hidden rounded-full border border-neutral-700 px-5 py-2 text-sm font-medium transition-colors hover:bg-neutral-100 hover:text-neutral-900 md:inline-block"
    >
      Réserver
    </a>

    <!-- Menu mobile (caché sur desktop) -->
    <MobileMenu client:load links={navLinks} />
  </nav>
</header>