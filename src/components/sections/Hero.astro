---
import Button from '../ui/Button.astro';
---

<section id="accueil" class="border-b border-neutral-800">
  <div class="mx-auto grid max-w-6xl gap-10 px-6 py-20 md:grid-cols-2 md:items-center">
    <!-- Colonne gauche : texte + CTA -->
    <div class="space-y-6">
      <p class="text-sm font-medium uppercase tracking-widest text-neutral-400">
        Coach sportif certifié · Nancy
      </p>

      <h1 class="text-4xl font-bold leading-tight tracking-tight md:text-5xl lg:text-6xl">
        Atteignez vos objectifs <br />
        avec un coaching <span class="text-neutral-400">sur-mesure</span>
      </h1>

      <p class="max-w-lg text-lg text-neutral-300">
        Programmes personnalisés, suivi hebdomadaire et méthode éprouvée
        pour transformer durablement votre corps et vos habitudes.
      </p>

      <div class="flex flex-wrap gap-3 pt-2">
        <Button href="#contact" variant="primary">
          Réserver ma séance découverte
        </Button>
        <Button href="#services" variant="secondary">
          Voir les programmes
        </Button>
      </div>
    </div>

    <!-- Colonne droite : image -->
    <div class="aspect-4/3 overflow-hidden rounded-2xl border border-neutral-800">
      <img
        src="https://images.unsplash.com/photo-1567013275689-c179a874478f?q=80&w=1200&auto=format&fit=crop"
        alt="Jane Doe, coach sportive, en pleine séance d'entraînement"
        class="h-full w-full object-cover object-[center_40%]"
        loading="eager"
        decoding="async"
        width="1200"
        height="900"
      />
    </div>
  </div>
</section>